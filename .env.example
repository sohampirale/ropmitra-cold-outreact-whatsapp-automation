# ==============================================================================
# ROPMITRA WHATSAPP AUTOMATION - ENVIRONMENT CONFIGURATION
# ==============================================================================

# Server Port
PORT=3001

# SQLite Database File Path (Will be auto-created if missing)
DB_PATH=./data/automation.db

# ==============================================================================
# EVOLUTION API SETTINGS
# ==============================================================================
# Base URL of your Evolution API server (e.g. https://evo.yourdomain.com)
EVOLUTION_API_URL=http://localhost:8080

# Global API Key configured in your Evolution API instance
EVOLUTION_API_KEY=your_evolution_api_global_key_here

# Enable Mock Mode for local development/testing when Evolution API is offline
# Set to 'true' to simulate QR codes, connections, and message delivery
MOCK_EVOLUTION_API=true

# ==============================================================================
# QUEUE WORKER SETTINGS
# ==============================================================================
# Default interval between sending messages in seconds (300 seconds = 5 minutes)
DEFAULT_SEND_INTERVAL_SECONDS=300

# Worker poll frequency in milliseconds (how often the DB worker checks the queue)
WORKER_POLL_INTERVAL_MS=3000
